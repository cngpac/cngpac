{
  "name": "cngpac",
  "version": "0.0.1",
  "description": "A highly configurable package release manager",
  "license": "Apache-2.0",
  "homepage": "https://cngpac.dev",
  "keywords": [],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cngpac/cngpac.git"
  },
  "bugs": {
    "url": "https://github.com/cngpac/cngpac/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=24.14.0"
  },
  "files": [
    "dist",
    "templates"
  ],
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/src/index.mjs",
    "./publishers/npm": "./dist/src/publishers/npm.mjs",
    "./releasers/github": "./dist/src/releasers/github.mjs",
    "./package.json": "./package.json"
  },
  "bin": {
    "cngpac": "dist/bin.mjs"
  },
  "scripts": {
    "format": "biome format --write && oxfmt **/*.{md,yml,css}",
    "format:check": "biome format --check && oxfmt --check **/*.{md,yml,css}",
    "lint": "biome lint --write",
    "typecheck-src": "tsc --noEmit --project tsconfig.json",
    "typecheck-cli": "tsc --noEmit --project src/cli/tsconfig.json",
    "typecheck-web": "tsc --noEmit --project website/tsconfig.json",
    "typecheck": "npm run typecheck-src && npm run typecheck-cli && npm run typecheck-web",
    "build-src": "tsdown --config tsdown.config.ts --exports",
    "build-cli": "tsdown --config src/cli/tsdown.config.ts",
    "build": "npm run build-src && npm run build-cli",
    "test": "vitest run",
    "test:watch": "vitest",
    "web": "cd website && npm run start"
  },
  "dependencies": {
    "semver": "^7.7.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@clack/prompts": "^1.2.0",
    "@octokit/rest": "^22.0.1",
    "@prettier/plugin-xml": "^3.4.2",
    "@types/mdast": "^4.0.4",
    "@types/node": "^24.12.2",
    "@types/semver": "^7.7.1",
    "commander": "^14.0.3",
    "glob": "^13.0.6",
    "localstorage-polyfill": "^1.0.1",
    "open": "^11.0.0",
    "oxfmt": "^0.44.0",
    "prettier": "^3.8.1",
    "rehype-stringify": "^10.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "remark-stringify": "^11.0.0",
    "simple-git": "^3.35.2",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "unified": "^11.0.5",
    "vitest": "^4.1.4",
    "yaml": "^2.8.3"
  },
  "inlinedDependencies": {
    "@clack/core": "1.2.0",
    "@clack/prompts": "1.2.0",
    "@kwsites/file-exists": "1.1.1",
    "@kwsites/promise-deferred": "1.1.1",
    "@octokit/auth-token": "6.0.0",
    "@octokit/core": "7.0.6",
    "@octokit/endpoint": "11.0.3",
    "@octokit/graphql": "9.0.3",
    "@octokit/plugin-paginate-rest": "14.0.0",
    "@octokit/plugin-request-log": "6.0.0",
    "@octokit/plugin-rest-endpoint-methods": "17.0.0",
    "@octokit/request": "10.0.8",
    "@octokit/request-error": "7.1.0",
    "@octokit/rest": "22.0.1",
    "@simple-git/args-pathspec": "1.0.2",
    "@simple-git/argv-parser": "1.0.3",
    "bail": "2.0.2",
    "before-after-hook": "4.0.0",
    "character-entities": "2.0.2",
    "debug": "4.4.3",
    "decode-named-character-reference": "1.3.0",
    "devlop": "1.1.0",
    "escape-string-regexp": "5.0.0",
    "extend": "3.0.2",
    "fast-content-type-parse": "3.0.0",
    "fast-string-truncated-width": "1.2.1",
    "fast-string-width": "1.1.0",
    "fast-wrap-ansi": "0.1.6",
    "fault": "2.0.1",
    "format": "0.2.2",
    "glob": "13.0.6",
    "has-flag": "4.0.0",
    "is-plain-obj": "4.1.0",
    "json-with-bigint": "3.5.8",
    "localstorage-polyfill": "1.0.1",
    "longest-streak": "3.1.0",
    "mdast-util-from-markdown": "2.0.3",
    "mdast-util-frontmatter": "2.0.1",
    "mdast-util-phrasing": "4.1.0",
    "mdast-util-to-markdown": "2.1.2",
    "mdast-util-to-string": "4.0.0",
    "micromark": "4.0.2",
    "micromark-core-commonmark": "2.0.3",
    "micromark-extension-frontmatter": "2.0.0",
    "micromark-factory-destination": "2.0.1",
    "micromark-factory-label": "2.0.1",
    "micromark-factory-space": "2.0.1",
    "micromark-factory-title": "2.0.1",
    "micromark-factory-whitespace": "2.0.1",
    "micromark-util-character": "2.1.1",
    "micromark-util-chunked": "2.0.1",
    "micromark-util-classify-character": "2.0.1",
    "micromark-util-combine-extensions": "2.0.1",
    "micromark-util-decode-numeric-character-reference": "2.0.2",
    "micromark-util-decode-string": "2.0.1",
    "micromark-util-html-tag-name": "2.0.1",
    "micromark-util-normalize-identifier": "2.0.1",
    "micromark-util-resolve-all": "2.0.1",
    "micromark-util-subtokenize": "2.1.0",
    "ms": "2.1.3",
    "remark-frontmatter": "5.0.0",
    "remark-parse": "11.0.0",
    "remark-stringify": "11.0.0",
    "simple-git": "3.35.2",
    "sisteransi": "1.0.5",
    "supports-color": "7.2.0",
    "trough": "2.2.0",
    "unified": "11.0.5",
    "unist-util-is": "6.0.1",
    "unist-util-stringify-position": "4.0.0",
    "unist-util-visit": "5.1.0",
    "unist-util-visit-parents": "6.0.2",
    "universal-user-agent": "7.0.3",
    "vfile": "6.0.3",
    "vfile-message": "4.0.3",
    "yaml": "2.8.3",
    "zwitch": "2.0.4"
  }
}
