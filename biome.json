{
  "$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "*.{ts,mts,json}",
      "src/*.{ts,json}",
      "src/**/*.{ts,json}",
      "{.changenotes,tests,website}/*.{ts,json}",
      "tests/**/*.{ts,json}",
      "website/{blog,docs,src}/**/*.{ts,tsx,js,cjs,json}",
      "!website/docs/api/**/*",
      ".vscode/*"
    ],
    "ignoreUnknown": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "json": {
    "parser": {
      "allowTrailingCommas": true
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
